generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum GlobalRole {
  PLAYER
  DM
}

enum CampaignRole {
  DM
  PLAYER
  ASSISTANT_DM
  SPECTATOR
}

enum InviteStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

enum ApprovalStatus {
  DRAFT
  PENDING_DM_REVIEW
  APPROVED_PRIVATE
  APPROVED_PUBLIC
  REJECTED
  NEEDS_CHANGES
  ARCHIVED
}

enum ContentVisibility {
  CAMPAIGN_ONLY
  PRIVATE_USER
  PUBLIC_LIBRARY
  OFFICIAL_ETERNUM
}

enum ContentType {
  CUSTOM_SPELL
  CUSTOM_ITEM
  CRAFTING_RECIPE
  MONSTER_NPC
  PROFESSION_PERK
  MAGICAL_DISCIPLINE
}

enum DiceVisibility {
  DM_ONLY
  ROLLER_AND_DM
  PARTY_VISIBLE
  PUBLIC
}

enum CastingAbility {
  CHA
  INT
  WIS
}

enum CampaignSessionStatus {
  PLANNED
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum ActivityType {
  CHARACTER_CREATED
  CHARACTER_UPDATED
  HOMEBREW_APPROVED
  HOMEBREW_PUBLISHED
  SESSION_CREATED
  SESSION_STARTED
  SESSION_ENDED
  DICE_ROLLED
  LOOT_AWARDED
  PROFESSION_LEVEL_GAINED
  SPELL_LEARNED
  ITEM_CRAFTED
  AFFINITY_GAINED
  NOTE_CREATED
}

enum AssistantThreadStatus {
  ACTIVE
  ARCHIVED
}

enum AssistantMessageRole {
  USER
  ASSISTANT
  SYSTEM
  TOOL
}

enum AssistantWorkflowType {
  CHARACTER_HELP
  SPELL_DRAFT
  ITEM_DRAFT
  NPC_DRAFT
  MONSTER_DRAFT
  QUEST_DRAFT
  RULE_EXPLANATION
  COMPENDIUM_HELP
  MAP_BLUEPRINT
  GENERAL
}

enum AssistantWorkflowStatus {
  DRAFTING
  WAITING_FOR_USER
  READY_TO_SAVE
  SUBMITTED_FOR_REVIEW
  COMPLETED
  ARCHIVED
}

enum NoteVisibility {
  DM_ONLY
  CAMPAIGN_SHARED
  CHARACTER_PRIVATE
}

enum TokenKind {
  CHARACTER
  MONSTER
  NPC
  OBJECT
}

enum MapVisibility {
  CAMPAIGN_ONLY
  PRIVATE_USER
  PUBLIC_LIBRARY
}

enum MapApprovalStatus {
  DRAFT
  PENDING_DM_REVIEW
  APPROVED_PRIVATE
  APPROVED_PUBLIC
  REJECTED
  ARCHIVED
}

enum MapGridType {
  SQUARE
  HEX
  NONE
}

enum MapSourceType {
  MANUAL
  AI_BLUEPRINT
  UPLOAD
  HYBRID
}

enum SubscriptionPlanCode {
  FREE
  DM
  WORLDBUILDER
  FOUNDER
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
  EXPIRED
  PAUSED
}

enum BillingEventType {
  CHECKOUT_CREATED
  SUBSCRIPTION_CREATED
  SUBSCRIPTION_UPDATED
  SUBSCRIPTION_CANCELED
  PAYMENT_SUCCEEDED
  PAYMENT_FAILED
  REFUND_CREATED
  WEBHOOK_RECEIVED
  MANUAL_ADJUSTMENT
}

model User {
  id            String    @id @default(cuid())
  name          String?
  username      String    @unique
  displayUsername String?
  email         String    @unique
  emailVerified DateTime?
  emailVerificationToken String? @unique
  emailVerificationExpires DateTime?
  image         String?
  passwordHash  String?
  isFounder     Boolean   @default(false)
  founderSince  DateTime?
  globalRoles   GlobalRole[] @default([PLAYER])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts       Account[]
  sessions       Session[]
  memberships    CampaignMember[]
  ownedCampaigns Campaign[] @relation("CampaignOwner")
  characters     Character[]
  invitesSent    CampaignInvite[] @relation("InviteSender")
  homebrew       HomebrewContent[]
  diceRolls      DiceRoll[]
  approvals      ApprovalRequest[] @relation("ApprovalReviewer")
  campaignSessions CampaignSession[] @relation("CampaignSessionCreator")
  activityLogs   ActivityLog[] @relation("ActivityActor")
  campaignNotes  CampaignNote[] @relation("CampaignNoteAuthor")
  mapsCreated    Map[] @relation("MapCreator")
  assistantThreads AssistantThread[]
  assistantMessages AssistantMessage[]
  subscriptions   UserSubscription[]
  billingEvents   BillingEvent[]
  aiUsage         AIUsage[]
}

model SubscriptionPlan {
  id          String               @id @default(cuid())
  code        SubscriptionPlanCode @unique
  name        String
  description String?
  monthlyPriceCents Int            @default(0)
  annualPriceCents  Int?
  features    Json                 @default("{}")
  active      Boolean              @default(true)
  sortOrder   Int                  @default(0)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  subscriptions UserSubscription[]
}

model UserSubscription {
  id                   String             @id @default(cuid())
  userId               String
  planId               String
  status               SubscriptionStatus @default(ACTIVE)
  startedAt            DateTime           @default(now())
  expiresAt            DateTime?
  squareCustomerId     String?
  squareSubscriptionId String?            @unique
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan          SubscriptionPlan @relation(fields: [planId], references: [id])
  billingEvents BillingEvent[]

  @@index([userId, status])
  @@index([planId])
}

model BillingEvent {
  id                 String           @id @default(cuid())
  userId             String?
  userSubscriptionId String?
  type               BillingEventType
  provider           String           @default("square")
  providerEventId    String?
  payload            Json             @default("{}")
  createdAt          DateTime         @default(now())

  user         User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  subscription UserSubscription? @relation(fields: [userSubscriptionId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([provider, providerEventId])
}

model AIUsage {
  id           String   @id @default(cuid())
  userId       String
  month        String
  requestCount Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Campaign {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  ownerId     String
  settings    Json     @default("{}")
  archivedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner      User              @relation("CampaignOwner", fields: [ownerId], references: [id])
  members    CampaignMember[]
  invites    CampaignInvite[]
  characters Character[]
  notes      SessionNote[]
  homebrew   HomebrewContent[]
  diceRolls  DiceRoll[]
  approvals  ApprovalRequest[]
  campaignSessions CampaignSession[]
  activityLogs ActivityLog[]
  campaignNotes CampaignNote[]
  characterMilestones CharacterMilestone[]
  maps       Map[]
  combatEncounters CombatEncounter[]
  assistantThreads AssistantThread[]
}

model CampaignMember {
  id         String       @id @default(cuid())
  campaignId String
  userId     String
  roles      CampaignRole[] @default([PLAYER])
  createdAt  DateTime     @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([campaignId, userId])
}

model CampaignInvite {
  id          String       @id @default(cuid())
  campaignId  String
  email       String
  roles       CampaignRole[] @default([PLAYER])
  token       String       @unique
  status      InviteStatus @default(PENDING)
  invitedById String
  expiresAt   DateTime
  createdAt   DateTime     @default(now())

  campaign  Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  invitedBy User     @relation("InviteSender", fields: [invitedById], references: [id])
}

model Character {
  id             String          @id @default(cuid())
  campaignId     String?
  ownerId        String
  name           String
  ancestry       String?
  className      String?
  level          Int             @default(1)
  castingAbility CastingAbility?
  strength       Int             @default(10)
  dexterity      Int             @default(10)
  constitution   Int             @default(10)
  intelligence   Int             @default(10)
  wisdom         Int             @default(10)
  charisma       Int             @default(10)
  backstory      String?         @db.Text
  inventory      Json            @default("[]")
  learnedSpells  Json            @default("[]")
  customSpells   Json            @default("[]")
  craftedItems   Json            @default("[]")
  disciplines    Json            @default("[]")
  traits         Json            @default("[]")
  flaws          Json            @default("[]")
  affinities     Json            @default("[]")
  tamedCreatures Json            @default("[]")
  undeadServants Json            @default("[]")
  approvedAt     DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  campaign         Campaign?            @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  owner            User                 @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  professionLevels ProfessionProgress[]
  backstoryAnalyses BackstoryAnalysis[]
  diceRolls        DiceRoll[]
  campaignNotes    CampaignNote[]
  milestones       CharacterMilestone[]
  mapTokens        MapToken[]
  initiativeEntries InitiativeEntry[]
  assistantThreads AssistantThread[]
}

model ProfessionProgress {
  id          String   @id @default(cuid())
  characterId String
  profession  String
  level       Int      @default(0)
  xp          Int      @default(0)
  updatedAt   DateTime @updatedAt

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@unique([characterId, profession])
}

model BackstoryAnalysis {
  id          String         @id @default(cuid())
  characterId String
  requestedBy String
  suggestion  Json
  status      ApprovalStatus @default(PENDING_DM_REVIEW)
  dmNotes     String?        @db.Text
  createdAt   DateTime       @default(now())
  reviewedAt  DateTime?

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
}

model HomebrewContent {
  id           String            @id @default(cuid())
  type         ContentType
  title        String
  slug         String
  summary      String?
  body         Json
  rulesResult  Json?
  rarity       String?
  discipline   String?
  professionRequirements Json @default("[]")
  imageUrl     String?
  imagePrompt  String?
  imageAltText String?
  generatedByAi Boolean @default(false)
  status       ApprovalStatus    @default(DRAFT)
  visibility   ContentVisibility @default(PRIVATE_USER)
  campaignId   String?
  authorId     String
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  publishRequestedAt DateTime?
  publishedAt  DateTime?

  campaign  Campaign?         @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  author    User              @relation(fields: [authorId], references: [id], onDelete: Cascade)
  approvals ApprovalRequest[]

  @@unique([type, slug])
}

model AssistantThread {
  id          String                @id @default(cuid())
  userId      String
  campaignId  String?
  characterId String?
  title       String
  status      AssistantThreadStatus @default(ACTIVE)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaign  Campaign?           @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  character Character?          @relation(fields: [characterId], references: [id], onDelete: SetNull)
  messages  AssistantMessage[]
  workflows AssistantWorkflow[]

  @@index([userId, updatedAt])
  @@index([campaignId, updatedAt])
  @@index([characterId, updatedAt])
}

model AssistantMessage {
  id                String               @id @default(cuid())
  threadId          String
  userId            String?
  role              AssistantMessageRole
  content           String               @db.Text
  structuredPayload Json                 @default("{}")
  createdAt         DateTime             @default(now())

  thread AssistantThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user   User?           @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([threadId, createdAt])
}

model AssistantWorkflow {
  id            String                  @id @default(cuid())
  threadId      String
  type          AssistantWorkflowType
  status        AssistantWorkflowStatus @default(DRAFTING)
  currentStep   String                  @default("intake")
  targetType    String?
  targetId      String?
  draftPayload  Json                    @default("{}")
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt

  thread AssistantThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId, status])
  @@index([type, status])
}

model ApprovalRequest {
  id          String         @id @default(cuid())
  campaignId  String
  homebrewId  String?
  reviewerId  String?
  status      ApprovalStatus @default(PENDING_DM_REVIEW)
  requestNote String?        @db.Text
  reviewNote  String?        @db.Text
  createdAt   DateTime       @default(now())
  reviewedAt  DateTime?

  campaign Campaign         @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  homebrew HomebrewContent? @relation(fields: [homebrewId], references: [id], onDelete: Cascade)
  reviewer User?            @relation("ApprovalReviewer", fields: [reviewerId], references: [id])
}

model SessionNote {
  id         String   @id @default(cuid())
  campaignId String
  title      String
  body       String   @db.Text
  visibleToPlayers Boolean @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

model CampaignSession {
  id            String                @id @default(cuid())
  campaignId    String
  title         String
  description   String?               @db.Text
  sessionNumber Int
  status        CampaignSessionStatus @default(PLANNED)
  startedAt     DateTime?
  endedAt       DateTime?
  createdById   String
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  campaign   Campaign          @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  createdBy  User              @relation("CampaignSessionCreator", fields: [createdById], references: [id])
  activities ActivityLog[]
  notes      CampaignNote[]
  milestones CharacterMilestone[]
  maps       Map[]
  encounters CombatEncounter[]

  @@unique([campaignId, sessionNumber])
}

model ActivityLog {
  id          String       @id @default(cuid())
  campaignId  String
  sessionId   String?
  actorId     String?
  type        ActivityType
  metadata    Json         @default("{}")
  createdAt   DateTime     @default(now())

  campaign Campaign         @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  session  CampaignSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  actor    User?            @relation("ActivityActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([campaignId, createdAt])
  @@index([sessionId, createdAt])
}

model CampaignNote {
  id          String         @id @default(cuid())
  campaignId  String
  sessionId   String?
  authorId    String
  characterId String?
  title       String
  body        String         @db.Text
  visibility  NoteVisibility @default(CAMPAIGN_SHARED)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  campaign  Campaign         @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  session   CampaignSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  author    User             @relation("CampaignNoteAuthor", fields: [authorId], references: [id])
  character Character?       @relation(fields: [characterId], references: [id], onDelete: SetNull)
}

model CharacterMilestone {
  id          String       @id @default(cuid())
  characterId String
  campaignId  String?
  sessionId   String?
  type        ActivityType
  title       String
  metadata    Json         @default("{}")
  createdAt   DateTime     @default(now())

  character Character        @relation(fields: [characterId], references: [id], onDelete: Cascade)
  campaign  Campaign?        @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  session   CampaignSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([characterId, createdAt])
}

model Map {
  id                    String            @id @default(cuid())
  campaignId            String?
  sessionId             String?
  name                  String
  description           String?
  visibility            MapVisibility     @default(CAMPAIGN_ONLY)
  approvalStatus        MapApprovalStatus @default(DRAFT)
  sourceType            MapSourceType     @default(MANUAL)
  blueprintVersion      Int               @default(1)
  editorState           Json              @default("{}")
  gridType              MapGridType       @default(SQUARE)
  width                 Int               @default(30)
  height                Int               @default(30)
  gridWidth             Int               @default(30)
  gridHeight            Int               @default(30)
  gridSize              Int               @default(70)
  recommendedPartyLevel Int?
  environment           String?
  theme                 String?
  prompt                String?           @db.Text
  interactiveNotes      String?           @db.Text
  spawnPoints           Json              @default("[]")
  lightingNotes         String?           @db.Text
  encounterSuggestions  Json              @default("[]")
  createdById           String
  publishedAt           DateTime?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  campaign  Campaign?        @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  session   CampaignSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  createdBy User             @relation("MapCreator", fields: [createdById], references: [id])
  images    MapImage[]
  tags      MapTag[]
  layers    MapLayer[]
  tokens    MapToken[]
  encounters CombatEncounter[]

  @@index([approvalStatus, visibility])
  @@index([campaignId])
  @@index([sessionId])
}

model MapImage {
  id            String   @id @default(cuid())
  mapId         String
  imageUrl      String
  imagePrompt   String?  @db.Text
  imageAltText  String?
  generatedByAi Boolean  @default(false)
  blobPath      String?
  width         Int?
  height        Int?
  createdAt     DateTime @default(now())

  map Map @relation(fields: [mapId], references: [id], onDelete: Cascade)
}

model MapTag {
  id        String   @id @default(cuid())
  mapId     String
  label     String
  category  String?
  createdAt DateTime @default(now())

  map Map @relation(fields: [mapId], references: [id], onDelete: Cascade)

  @@unique([mapId, label])
}

model MapLayer {
  id       String  @id @default(cuid())
  mapId    String
  name     String
  order    Int     @default(0)
  visible  Boolean @default(true)
  locked   Boolean @default(false)
  data     Json    @default("{}")

  map Map @relation(fields: [mapId], references: [id], onDelete: Cascade)
}

model MapToken {
  id          String    @id @default(cuid())
  mapId       String
  characterId String?
  kind        TokenKind @default(CHARACTER)
  name        String
  monsterRef  String?
  x           Float     @default(0)
  y           Float     @default(0)
  size        Float     @default(1)
  hp          Int?
  maxHp       Int?
  hidden      Boolean   @default(false)
  metadata    Json      @default("{}")

  map       Map        @relation(fields: [mapId], references: [id], onDelete: Cascade)
  character Character? @relation(fields: [characterId], references: [id], onDelete: SetNull)
  initiativeEntries InitiativeEntry[]
}

model CombatEncounter {
  id          String   @id @default(cuid())
  campaignId  String
  sessionId   String?
  mapId       String?
  name        String
  status      String   @default("planned")
  round       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  campaign Campaign         @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  session  CampaignSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  map      Map?             @relation(fields: [mapId], references: [id], onDelete: SetNull)
  initiative InitiativeEntry[]
}

model InitiativeEntry {
  id          String  @id @default(cuid())
  encounterId String
  characterId String?
  tokenId     String?
  name        String
  initiative  Int
  order       Int
  active      Boolean @default(false)
  metadata    Json    @default("{}")

  encounter CombatEncounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)
  character Character?      @relation(fields: [characterId], references: [id], onDelete: SetNull)
  token     MapToken?       @relation(fields: [tokenId], references: [id], onDelete: SetNull)
}

model DiceRoll {
  id          String         @id @default(cuid())
  campaignId  String
  characterId String?
  rollerId    String
  expression  String
  label       String?
  visibility  DiceVisibility
  total       Int
  detail      Json
  revealedAt  DateTime?
  createdAt   DateTime       @default(now())

  campaign  Campaign   @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  character Character? @relation(fields: [characterId], references: [id], onDelete: SetNull)
  roller    User       @relation(fields: [rollerId], references: [id], onDelete: Cascade)
}
