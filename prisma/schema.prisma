generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum GlobalRole {
  PLAYER
  DM
}

enum CampaignRole {
  DM
  PLAYER
  ASSISTANT_DM
  SPECTATOR
}

enum InviteStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

enum ApprovalStatus {
  DRAFT
  PENDING_DM_REVIEW
  APPROVED_PRIVATE
  APPROVED_PUBLIC
  REJECTED
  NEEDS_CHANGES
  ARCHIVED
}

enum ContentVisibility {
  CAMPAIGN_ONLY
  PRIVATE_USER
  PUBLIC_LIBRARY
  OFFICIAL_ETERNUM
}

enum ContentType {
  CUSTOM_SPELL
  CUSTOM_ITEM
  CRAFTING_RECIPE
  MONSTER_NPC
  PROFESSION_PERK
  MAGICAL_DISCIPLINE
  TRAIT
  AFFINITY
  COMPANION
  UNDEAD_SERVANT
  HOMEBREW_ABILITY
}

enum SrdEntryType {
  SPECIES
  LANGUAGE
  PROFICIENCY
  TRAIT
  EQUIPMENT
  SPELL
  MONSTER
  CONDITION
  RULE
  ITEM
}

enum DiceVisibility {
  DM_ONLY
  ROLLER_AND_DM
  PARTY_VISIBLE
  PUBLIC
}

enum CastingAbility {
  CHA
  INT
  WIS
}

enum CampaignSessionStatus {
  PLANNED
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum ActivityType {
  CHARACTER_CREATED
  CHARACTER_UPDATED
  HOMEBREW_APPROVED
  HOMEBREW_PUBLISHED
  HOMEBREW_SUBMITTED
  HOMEBREW_DENIED
  HOMEBREW_CHANGES_REQUESTED
  HOMEBREW_RESUBMITTED
  SESSION_CREATED
  SESSION_STARTED
  SESSION_ENDED
  DICE_ROLLED
  LOOT_AWARDED
  PROFESSION_LEVEL_GAINED
  SPELL_LEARNED
  ITEM_CRAFTED
  AFFINITY_GAINED
  NOTE_CREATED
  MAP_UPDATED
  TOKEN_MOVED
  FOG_UPDATED
}

enum AssistantThreadStatus {
  ACTIVE
  ARCHIVED
}

enum AssistantMessageRole {
  USER
  ASSISTANT
  SYSTEM
  TOOL
}

enum AssistantWorkflowType {
  CHARACTER_HELP
  BACKSTORY_ANALYSIS
  SPELL_DRAFT
  ITEM_DRAFT
  NPC_DRAFT
  NPC_ROLEPLAY
  MONSTER_DRAFT
  QUEST_DRAFT
  WORLDBUILDING
  RULE_EXPLANATION
  COMPENDIUM_HELP
  MAP_BLUEPRINT
  CRAFTING_HELP
  CURRENCY_HELP
  LOOT_UPDATE
  SESSION_LISTENER
  SESSION_MEMORY
  CAMPAIGN_MEMORY_QUERY
  GENERAL
}

enum AssistantWorkflowStatus {
  DRAFTING
  WAITING_FOR_USER
  READY_TO_SAVE
  SUBMITTED_FOR_REVIEW
  COMPLETED
  ARCHIVED
}

enum NoteVisibility {
  DM_ONLY
  CAMPAIGN_SHARED
  CHARACTER_PRIVATE
}

enum TokenKind {
  CHARACTER
  MONSTER
  NPC
  OBJECT
}

enum MapVisibility {
  CAMPAIGN_ONLY
  PRIVATE_USER
  PUBLIC_LIBRARY
}

enum MapApprovalStatus {
  DRAFT
  PENDING_DM_REVIEW
  APPROVED_PRIVATE
  APPROVED_PUBLIC
  REJECTED
  ARCHIVED
}

enum MapGridType {
  SQUARE
  HEX
  NONE
}

enum MapSourceType {
  MANUAL
  AI_BLUEPRINT
  UPLOAD
  HYBRID
  DUNGEON_SCRAWL
}

enum SubscriptionPlanCode {
  FREE
  DM
  WORLDBUILDER
  FOUNDER
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
  EXPIRED
  PAUSED
}

enum BillingEventType {
  CHECKOUT_CREATED
  MARKETPLACE_CHECKOUT_CREATED
  SUBSCRIPTION_CREATED
  SUBSCRIPTION_UPDATED
  SUBSCRIPTION_CANCELED
  SUBSCRIPTION_CHECKOUT_CREATED
  PAYMENT_SUCCEEDED
  PAYMENT_FAILED
  ENTITLEMENT_GRANTED
  REFUND_CREATED
  WEBHOOK_RECEIVED
  MANUAL_ADJUSTMENT
}

enum BillingSource {
  SQUARE
  MANUAL
  FOUNDER
}

enum MarketplaceProductType {
  COMPENDIUM
  RULESET
  ASSET_PACK
  MAP_PACK
  TOKEN_PACK
  CAMPAIGN_MODULE
  AI_CREDIT_PACK
  HOMEBREW_PACK
}

enum MarketplaceProductStatus {
  DRAFT
  PENDING_REVIEW
  ACTIVE
  ARCHIVED
}

enum PurchaseStatus {
  PENDING
  PAID
  FAILED
  CANCELED
  REFUNDED
}

enum TranscriptIntent {
  DM_NARRATION
  PLAYER_ACTION
  LOOT_FOUND
  LOOT_CLAIMED
  NPC_DIALOGUE
  COMBAT_ACTION
  RULES_QUESTION
  QUEST_UPDATE
  NOTEWORTHY_EVENT
  TABLE_CHATTER
  UNKNOWN
}

enum PendingUpdateStatus {
  PENDING
  APPROVED
  REJECTED
  NEEDS_CHANGES
  APPLIED
  ARCHIVED
}

enum HandoutVisibility {
  DM_ONLY
  REVEALED_ALL
  SELECTED_PLAYERS
  SELECTED_CHARACTERS
  HIDDEN
}

enum CurrencyTransactionType {
  TRANSFER
  LOOT
  SPLIT
  MANUAL_ADJUSTMENT
  CRAFTING_SALE
  PURCHASE
  TREASURY_DEPOSIT
  TREASURY_WITHDRAWAL
}

enum CurrencyTransactionStatus {
  PENDING
  APPROVED
  REJECTED
  APPLIED
}

model User {
  id            String    @id @default(cuid())
  name          String?
  username      String    @unique
  displayUsername String?
  email         String    @unique
  emailVerified DateTime?
  emailVerificationToken String? @unique
  emailVerificationExpires DateTime?
  image         String?
  passwordHash  String?
  isFounder     Boolean   @default(false)
  founderSince  DateTime?
  globalRoles   GlobalRole[] @default([PLAYER])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts       Account[]
  sessions       Session[]
  memberships    CampaignMember[]
  ownedCampaigns Campaign[] @relation("CampaignOwner")
  characters     Character[]
  invitesSent    CampaignInvite[] @relation("InviteSender")
  homebrew       HomebrewContent[]
  diceRolls      DiceRoll[]
  approvals      ApprovalRequest[] @relation("ApprovalReviewer")
  reviewedHomebrew HomebrewContent[] @relation("HomebrewReviewer")
  submittedHomebrewRevisions HomebrewRevision[] @relation("HomebrewRevisionSubmitter")
  reviewedHomebrewRevisions HomebrewRevision[] @relation("HomebrewRevisionReviewer")
  campaignSessions CampaignSession[] @relation("CampaignSessionCreator")
  activityLogs   ActivityLog[] @relation("ActivityActor")
  campaignNotes  CampaignNote[] @relation("CampaignNoteAuthor")
  mapsCreated    Map[] @relation("MapCreator")
  assistantThreads AssistantThread[]
  assistantMessages AssistantMessage[]
  currencyTransactions CurrencyTransaction[] @relation("CurrencyTransactionActor")
  subscriptions   UserSubscription[]
  billingEvents   BillingEvent[]
  marketplaceProducts MarketplaceProduct[] @relation("MarketplaceProductCreator")
  marketplacePurchases MarketplacePurchase[]
  userEntitlements UserEntitlement[]
  aiUsage         AIUsage[]
}

model SubscriptionPlan {
  id          String               @id @default(cuid())
  code        SubscriptionPlanCode @unique
  name        String
  description String?
  monthlyPriceCents Int            @default(0)
  annualPriceCents  Int?
  features    Json                 @default("{}")
  active      Boolean              @default(true)
  sortOrder   Int                  @default(0)
  squareCatalogObjectId String?
  squareVariationId     String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  subscriptions UserSubscription[]
}

model UserSubscription {
  id                   String             @id @default(cuid())
  userId               String
  planId               String
  status               SubscriptionStatus @default(ACTIVE)
  source               BillingSource      @default(MANUAL)
  startedAt            DateTime           @default(now())
  currentPeriodEnd     DateTime?
  expiresAt            DateTime?
  squareCustomerId     String?
  squareSubscriptionId String?            @unique
  squareCheckoutOrderId String?
  squareCheckoutPaymentLinkId String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan          SubscriptionPlan @relation(fields: [planId], references: [id])
  billingEvents BillingEvent[]

  @@index([userId, status])
  @@index([planId])
  @@index([squareCheckoutOrderId])
  @@index([squareCheckoutPaymentLinkId])
}

model BillingEvent {
  id                 String           @id @default(cuid())
  userId             String?
  userSubscriptionId String?
  type               BillingEventType
  provider           String           @default("square")
  providerEventId    String?
  payload            Json             @default("{}")
  createdAt          DateTime         @default(now())

  user         User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  subscription UserSubscription? @relation(fields: [userSubscriptionId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([provider, providerEventId])
}

model MarketplaceProduct {
  id          String                   @id @default(cuid())
  creatorId   String?
  name        String
  slug        String                   @unique
  description String?
  type        MarketplaceProductType
  status      MarketplaceProductStatus @default(DRAFT)
  priceCents  Int                      @default(0)
  currency    String                   @default("USD")
  coverImageUrl String?
  tags        Json                     @default("[]")
  includedContent Json                 @default("{}")
  official    Boolean                  @default(false)
  squareCatalogObjectId String?
  squareVariationId     String?
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt

  creator User? @relation("MarketplaceProductCreator", fields: [creatorId], references: [id], onDelete: SetNull)
  purchases MarketplacePurchase[]
  userEntitlements UserEntitlement[]
  campaignEntitlements CampaignEntitlement[]
}

model MarketplacePurchase {
  id          String         @id @default(cuid())
  userId      String
  productId   String
  status      PurchaseStatus @default(PENDING)
  amountCents Int
  currency    String         @default("USD")
  squarePaymentId String?
  squareOrderId   String?
  checkoutUrl     String?
  metadata    Json           @default("{}")
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  product MarketplaceProduct @relation(fields: [productId], references: [id])

  @@index([userId, status])
  @@index([productId, status])
}

model UserEntitlement {
  id        String   @id @default(cuid())
  userId    String
  productId String
  source    String   @default("purchase")
  active    Boolean  @default(true)
  grantedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  product MarketplaceProduct @relation(fields: [productId], references: [id])

  @@unique([userId, productId])
}

model CampaignEntitlement {
  id         String   @id @default(cuid())
  campaignId String
  productId  String
  enabledById String?
  active     Boolean  @default(true)
  grantedAt  DateTime @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  product MarketplaceProduct @relation(fields: [productId], references: [id])

  @@unique([campaignId, productId])
}

model AIUsage {
  id           String   @id @default(cuid())
  userId       String
  month        String
  requestCount Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month])
}

model SrdSource {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  version     String?
  baseUrl     String?
  license     String   @default("SRD / Creative Commons")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  entries SrdEntry[]
}

model SrdEntry {
  id           String       @id @default(cuid())
  sourceId     String
  type         SrdEntryType
  slug         String
  name         String
  summary      String?
  version      String?
  licenseLabel String       @default("SRD / Creative Commons")
  sourceUrl    String?
  raw          Json         @default("{}")
  normalized   Json         @default("{}")
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  source SrdSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([sourceId, type, slug])
  @@index([type, name])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Campaign {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  ownerId     String
  settings    Json     @default("{}")
  archivedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner      User              @relation("CampaignOwner", fields: [ownerId], references: [id])
  members    CampaignMember[]
  invites    CampaignInvite[]
  characters Character[]
  notes      SessionNote[]
  homebrew   HomebrewContent[]
  diceRolls  DiceRoll[]
  approvals  ApprovalRequest[]
  campaignSessions CampaignSession[]
  activityLogs ActivityLog[]
  campaignNotes CampaignNote[]
  characterMilestones CharacterMilestone[]
  maps       Map[]
  combatEncounters CombatEncounter[]
  assistantThreads AssistantThread[]
  partyTreasury PartyTreasury?
  currencyTransactions CurrencyTransaction[]
  campaignEntitlements CampaignEntitlement[]
  liveState CampaignLiveState?
  mapFogStates MapFogState[]
}

model CampaignMember {
  id         String       @id @default(cuid())
  campaignId String
  userId     String
  roles      CampaignRole[] @default([PLAYER])
  createdAt  DateTime     @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([campaignId, userId])
}

model CampaignInvite {
  id          String       @id @default(cuid())
  campaignId  String
  email       String
  roles       CampaignRole[] @default([PLAYER])
  token       String       @unique
  status      InviteStatus @default(PENDING)
  invitedById String
  expiresAt   DateTime
  createdAt   DateTime     @default(now())

  campaign  Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  invitedBy User     @relation("InviteSender", fields: [invitedById], references: [id])
}

model Character {
  id             String          @id @default(cuid())
  campaignId     String?
  ownerId        String
  name           String
  displayTitle   String?
  portraitUrl    String?
  ancestry       String?
  speciesSlug    String?
  speciesSource  String?
  speciesTraits  Json            @default("[]")
  className      String?
  trainingFocus  Json            @default("[]")
  level          Int             @default(1)
  castingAbility CastingAbility?
  strength       Int             @default(10)
  dexterity      Int             @default(10)
  constitution   Int             @default(10)
  intelligence   Int             @default(10)
  wisdom         Int             @default(10)
  charisma       Int             @default(10)
  backstory      String?         @db.Text
  inventory      Json            @default("[]")
  learnedSpells  Json            @default("[]")
  customSpells   Json            @default("[]")
  craftedItems   Json            @default("[]")
  disciplines    Json            @default("[]")
  traits         Json            @default("[]")
  flaws          Json            @default("[]")
  affinities     Json            @default("[]")
  tamedCreatures Json            @default("[]")
  undeadServants Json            @default("[]")
  approvedAt     DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  campaign         Campaign?            @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  owner            User                 @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  professionLevels ProfessionProgress[]
  backstoryAnalyses BackstoryAnalysis[]
  diceRolls        DiceRoll[]
  campaignNotes    CampaignNote[]
  milestones       CharacterMilestone[]
  mapTokens        MapToken[]
  initiativeEntries InitiativeEntry[]
  assistantThreads AssistantThread[]
  homebrewSubmissions HomebrewContent[] @relation("CharacterHomebrewSubmissions")
  wallet           CharacterWallet?
  currencyTransactions CurrencyTransaction[]
}

model CharacterWallet {
  id          String   @id @default(cuid())
  characterId String  @unique
  balanceCp   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
}

model PartyTreasury {
  id         String   @id @default(cuid())
  campaignId String  @unique
  balanceCp  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  transactions CurrencyTransaction[]
}

model CurrencyTransaction {
  id          String                    @id @default(cuid())
  campaignId  String?
  characterId String?
  treasuryId  String?
  actorId     String?
  type        CurrencyTransactionType
  status      CurrencyTransactionStatus @default(APPLIED)
  amountCp    Int
  note        String?
  metadata    Json                      @default("{}")
  createdAt   DateTime                  @default(now())
  appliedAt   DateTime?

  campaign  Campaign?      @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  character Character?     @relation(fields: [characterId], references: [id], onDelete: SetNull)
  treasury  PartyTreasury? @relation(fields: [treasuryId], references: [id], onDelete: SetNull)
  actor     User?          @relation("CurrencyTransactionActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([characterId, createdAt])
  @@index([campaignId, createdAt])
  @@index([treasuryId, createdAt])
}

model ProfessionProgress {
  id          String   @id @default(cuid())
  characterId String
  profession  String
  level       Int      @default(0)
  xp          Int      @default(0)
  updatedAt   DateTime @updatedAt

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@unique([characterId, profession])
}

model BackstoryAnalysis {
  id          String         @id @default(cuid())
  characterId String
  requestedBy String
  suggestion  Json
  status      ApprovalStatus @default(PENDING_DM_REVIEW)
  dmNotes     String?        @db.Text
  createdAt   DateTime       @default(now())
  reviewedAt  DateTime?

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
}

model HomebrewContent {
  id           String            @id @default(cuid())
  type         ContentType
  title        String
  slug         String
  summary      String?
  body         Json
  rulesResult  Json?
  rarity       String?
  discipline   String?
  professionRequirements Json @default("[]")
  imageUrl     String?
  imagePrompt  String?
  imageAltText String?
  generatedByAi Boolean @default(false)
  status       ApprovalStatus    @default(DRAFT)
  visibility   ContentVisibility @default(PRIVATE_USER)
  campaignId   String?
  characterId  String?
  authorId     String
  submittedAt  DateTime?
  reviewedAt   DateTime?
  reviewedByUserId String?
  dmFeedback   String?           @db.Text
  currentRevisionId String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  publishRequestedAt DateTime?
  publishedAt  DateTime?

  campaign  Campaign?         @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  character Character?        @relation("CharacterHomebrewSubmissions", fields: [characterId], references: [id], onDelete: SetNull)
  author    User              @relation(fields: [authorId], references: [id], onDelete: Cascade)
  reviewedBy User?            @relation("HomebrewReviewer", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  approvals ApprovalRequest[]
  revisions HomebrewRevision[]

  @@unique([type, slug])
  @@index([characterId, status])
  @@index([campaignId, status])
  @@index([authorId, updatedAt])
}

model HomebrewRevision {
  id              String          @id @default(cuid())
  homebrewId      String
  revisionNumber  Int
  contentSnapshot Json
  submittedById   String
  submittedAt     DateTime        @default(now())
  dmFeedback      String?         @db.Text
  dmDecision      ApprovalStatus?
  reviewedById    String?
  reviewedAt      DateTime?

  homebrew    HomebrewContent @relation(fields: [homebrewId], references: [id], onDelete: Cascade)
  submittedBy User            @relation("HomebrewRevisionSubmitter", fields: [submittedById], references: [id], onDelete: Cascade)
  reviewedBy  User?           @relation("HomebrewRevisionReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@unique([homebrewId, revisionNumber])
  @@index([homebrewId, submittedAt])
}

model AssistantThread {
  id          String                @id @default(cuid())
  userId      String
  campaignId  String?
  characterId String?
  title       String
  status      AssistantThreadStatus @default(ACTIVE)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaign  Campaign?           @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  character Character?          @relation(fields: [characterId], references: [id], onDelete: SetNull)
  messages  AssistantMessage[]
  workflows AssistantWorkflow[]

  @@index([userId, updatedAt])
  @@index([campaignId, updatedAt])
  @@index([characterId, updatedAt])
}

model AssistantMessage {
  id                String               @id @default(cuid())
  threadId          String
  userId            String?
  role              AssistantMessageRole
  content           String               @db.Text
  structuredPayload Json                 @default("{}")
  createdAt         DateTime             @default(now())

  thread AssistantThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user   User?           @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([threadId, createdAt])
}

model AssistantWorkflow {
  id            String                  @id @default(cuid())
  threadId      String
  type          AssistantWorkflowType
  status        AssistantWorkflowStatus @default(DRAFTING)
  currentStep   String                  @default("intake")
  targetType    String?
  targetId      String?
  draftPayload  Json                    @default("{}")
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt

  thread AssistantThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId, status])
  @@index([type, status])
}

model Npc {
  id                   String   @id @default(cuid())
  campaignId           String?
  createdById          String
  name                 String
  appearance           String?  @db.Text
  personality          String?  @db.Text
  voiceMannerisms      String?  @db.Text
  goals                Json     @default("[]")
  secrets              Json     @default("[]")
  knowledge            Json     @default("{}")
  faction              String?
  relationships        Json     @default("[]")
  emotionalState       String?
  hiddenDmInstructions String?  @db.Text
  roleplayEnabled      Boolean  @default(false)
  autoSendLowRisk      Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  memories      NpcMemory[]
  conversations NpcConversation[]

  @@index([campaignId, name])
  @@index([createdById, updatedAt])
}

model NpcMemory {
  id        String   @id @default(cuid())
  npcId     String
  scope     String   @default("campaign")
  content   String   @db.Text
  metadata  Json     @default("{}")
  createdAt DateTime @default(now())

  npc Npc @relation(fields: [npcId], references: [id], onDelete: Cascade)

  @@index([npcId, createdAt])
}

model NpcConversation {
  id         String   @id @default(cuid())
  npcId      String
  campaignId String?
  sessionId  String?
  status     String   @default("active")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  npc      Npc          @relation(fields: [npcId], references: [id], onDelete: Cascade)
  messages NpcMessage[]

  @@index([campaignId, updatedAt])
  @@index([npcId, updatedAt])
}

model NpcMessage {
  id             String   @id @default(cuid())
  conversationId String
  speakerType    String
  speakerUserId  String?
  speakerCharacterId String?
  content        String   @db.Text
  approvedByDm   Boolean  @default(false)
  hiddenFromPlayers Boolean @default(false)
  metadata       Json     @default("{}")
  createdAt      DateTime @default(now())

  conversation NpcConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model TranscriptSegment {
  id                 String           @id @default(cuid())
  sessionId          String
  speakerUserId      String?
  speakerCharacterId String?
  isDm               Boolean          @default(false)
  confidence         Float            @default(0)
  rawText            String           @db.Text
  correctedText      String?          @db.Text
  timestamp          DateTime         @default(now())
  intent             TranscriptIntent @default(UNKNOWN)
  metadata           Json             @default("{}")
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@index([sessionId, timestamp])
  @@index([intent])
}

model VoiceProfile {
  id             String   @id @default(cuid())
  userId         String?
  characterId    String?
  npcId          String?
  provider       String   @default("none")
  providerVoiceId String?
  displayName    String
  sampleMetadata Json     @default("{}")
  consentRecordedAt DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
  @@index([characterId])
  @@index([npcId])
}

model LootEvent {
  id          String              @id @default(cuid())
  campaignId  String
  sessionId   String?
  createdById String?
  source      String              @default("manual")
  description String              @db.Text
  currencyCopper Int              @default(0)
  items       Json                @default("[]")
  status      PendingUpdateStatus @default(PENDING)
  metadata    Json                @default("{}")
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  claims LootClaim[]

  @@index([campaignId, status])
  @@index([sessionId, createdAt])
}

model LootClaim {
  id          String              @id @default(cuid())
  lootEventId String
  characterId String?
  userId      String?
  claimNote   String?             @db.Text
  currencyCopper Int              @default(0)
  items       Json                @default("[]")
  status      PendingUpdateStatus @default(PENDING)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  lootEvent LootEvent @relation(fields: [lootEventId], references: [id], onDelete: Cascade)

  @@index([lootEventId, status])
  @@index([characterId, status])
}

model PendingInventoryUpdate {
  id             String              @id @default(cuid())
  campaignId     String
  characterId    String?
  userId         String?
  sourceType     String
  sourceId       String?
  currencyCopper Int                 @default(0)
  items          Json                @default("[]")
  note           String?             @db.Text
  status         PendingUpdateStatus @default(PENDING)
  createdAt      DateTime            @default(now())
  reviewedAt     DateTime?

  @@index([campaignId, status])
  @@index([characterId, status])
}

model CampaignHandout {
  id             String            @id @default(cuid())
  campaignId     String
  sessionId      String?
  createdById    String
  title          String
  type           String            @default("lore")
  body           String            @db.Text
  imageUrl       String?
  visibility     HandoutVisibility @default(DM_ONLY)
  revealedTo     Json              @default("[]")
  metadata       Json              @default("{}")
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([campaignId, visibility])
  @@index([sessionId, updatedAt])
}

model ApprovalRequest {
  id          String         @id @default(cuid())
  campaignId  String
  homebrewId  String?
  reviewerId  String?
  status      ApprovalStatus @default(PENDING_DM_REVIEW)
  requestNote String?        @db.Text
  reviewNote  String?        @db.Text
  createdAt   DateTime       @default(now())
  reviewedAt  DateTime?

  campaign Campaign         @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  homebrew HomebrewContent? @relation(fields: [homebrewId], references: [id], onDelete: Cascade)
  reviewer User?            @relation("ApprovalReviewer", fields: [reviewerId], references: [id])
}

model SessionNote {
  id         String   @id @default(cuid())
  campaignId String
  title      String
  body       String   @db.Text
  visibleToPlayers Boolean @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

model CampaignSession {
  id            String                @id @default(cuid())
  campaignId    String
  title         String
  description   String?               @db.Text
  sessionNumber Int
  status        CampaignSessionStatus @default(PLANNED)
  startedAt     DateTime?
  endedAt       DateTime?
  createdById   String
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  campaign   Campaign          @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  createdBy  User              @relation("CampaignSessionCreator", fields: [createdById], references: [id])
  activities ActivityLog[]
  notes      CampaignNote[]
  milestones CharacterMilestone[]
  maps       Map[]
  encounters CombatEncounter[]
  liveStates CampaignLiveState[]

  @@unique([campaignId, sessionNumber])
}

model ActivityLog {
  id          String       @id @default(cuid())
  campaignId  String
  sessionId   String?
  actorId     String?
  type        ActivityType
  metadata    Json         @default("{}")
  createdAt   DateTime     @default(now())

  campaign Campaign         @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  session  CampaignSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  actor    User?            @relation("ActivityActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([campaignId, createdAt])
  @@index([sessionId, createdAt])
}

model CampaignNote {
  id          String         @id @default(cuid())
  campaignId  String
  sessionId   String?
  authorId    String
  characterId String?
  title       String
  body        String         @db.Text
  visibility  NoteVisibility @default(CAMPAIGN_SHARED)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  campaign  Campaign         @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  session   CampaignSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  author    User             @relation("CampaignNoteAuthor", fields: [authorId], references: [id])
  character Character?       @relation(fields: [characterId], references: [id], onDelete: SetNull)
}

model CharacterMilestone {
  id          String       @id @default(cuid())
  characterId String
  campaignId  String?
  sessionId   String?
  type        ActivityType
  title       String
  metadata    Json         @default("{}")
  createdAt   DateTime     @default(now())

  character Character        @relation(fields: [characterId], references: [id], onDelete: Cascade)
  campaign  Campaign?        @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  session   CampaignSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([characterId, createdAt])
}

model Map {
  id                    String            @id @default(cuid())
  campaignId            String?
  sessionId             String?
  name                  String
  description           String?
  visibility            MapVisibility     @default(CAMPAIGN_ONLY)
  approvalStatus        MapApprovalStatus @default(DRAFT)
  sourceType            MapSourceType     @default(MANUAL)
  blueprintVersion      Int               @default(1)
  editorState           Json              @default("{}")
  gridType              MapGridType       @default(SQUARE)
  width                 Int               @default(30)
  height                Int               @default(30)
  gridWidth             Int               @default(30)
  gridHeight            Int               @default(30)
  gridSize              Int               @default(70)
  recommendedPartyLevel Int?
  environment           String?
  theme                 String?
  prompt                String?           @db.Text
  sourceFileName        String?
  importWarnings        Json              @default("[]")
  importVersion         String?
  importedAt            DateTime?
  importedByUserId      String?
  interactiveNotes      String?           @db.Text
  spawnPoints           Json              @default("[]")
  lightingNotes         String?           @db.Text
  encounterSuggestions  Json              @default("[]")
  createdById           String
  publishedAt           DateTime?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  campaign  Campaign?        @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  session   CampaignSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  createdBy User             @relation("MapCreator", fields: [createdById], references: [id])
  images    MapImage[]
  tags      MapTag[]
  layers    MapLayer[]
  tokens    MapToken[]
  fogStates MapFogState[]
  liveStates CampaignLiveState[] @relation("ActiveLiveMap")
  encounters CombatEncounter[]

  @@index([approvalStatus, visibility])
  @@index([campaignId])
  @@index([sessionId])
}

model CampaignLiveState {
  id                 String   @id @default(cuid())
  campaignId         String   @unique
  activeSessionId    String?
  activeMapId        String?
  fogEnabled         Boolean  @default(false)
  gridEnabled        Boolean  @default(true)
  currentRound       Int      @default(0)
  currentTurnTokenId String?
  metadata           Json     @default("{}")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  activeMap Map? @relation("ActiveLiveMap", fields: [activeMapId], references: [id], onDelete: SetNull)
  activeSession CampaignSession? @relation(fields: [activeSessionId], references: [id], onDelete: SetNull)

  @@index([activeMapId])
  @@index([activeSessionId])
}

model MapFogState {
  id              String   @id @default(cuid())
  campaignId      String
  mapId           String
  enabled         Boolean  @default(false)
  revealedRegions Json     @default("[]")
  hiddenRegions   Json     @default("[]")
  updatedById     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  map Map @relation(fields: [mapId], references: [id], onDelete: Cascade)

  @@unique([campaignId, mapId])
  @@index([mapId])
}

model MapImage {
  id            String   @id @default(cuid())
  mapId         String
  imageUrl      String
  imagePrompt   String?  @db.Text
  imageAltText  String?
  generatedByAi Boolean  @default(false)
  blobPath      String?
  width         Int?
  height        Int?
  createdAt     DateTime @default(now())

  map Map @relation(fields: [mapId], references: [id], onDelete: Cascade)
}

model MapTag {
  id        String   @id @default(cuid())
  mapId     String
  label     String
  category  String?
  createdAt DateTime @default(now())

  map Map @relation(fields: [mapId], references: [id], onDelete: Cascade)

  @@unique([mapId, label])
}

model MapLayer {
  id       String  @id @default(cuid())
  mapId    String
  name     String
  order    Int     @default(0)
  visible  Boolean @default(true)
  locked   Boolean @default(false)
  data     Json    @default("{}")

  map Map @relation(fields: [mapId], references: [id], onDelete: Cascade)
}

model MapToken {
  id          String    @id @default(cuid())
  campaignId  String?
  mapId       String
  characterId String?
  kind        TokenKind @default(CHARACTER)
  name        String
  imageUrl    String?
  monsterRef  String?
  x           Float     @default(0)
  y           Float     @default(0)
  width       Float     @default(1)
  height      Float     @default(1)
  size        Float     @default(1)
  rotation    Float     @default(0)
  layer       String    @default("tokens")
  visibility  String    @default("PARTY_VISIBLE")
  ownerUserId String?
  controlledByUserIds Json @default("[]")
  hp          Int?
  maxHp       Int?
  hidden      Boolean   @default(false)
  locked      Boolean   @default(false)
  conditions  Json      @default("[]")
  notes       Json      @default("{}")
  lastMovedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  metadata    Json      @default("{}")

  map       Map        @relation(fields: [mapId], references: [id], onDelete: Cascade)
  character Character? @relation(fields: [characterId], references: [id], onDelete: SetNull)
  initiativeEntries InitiativeEntry[]

  @@index([campaignId, mapId])
  @@index([ownerUserId])
}

model CombatEncounter {
  id          String   @id @default(cuid())
  campaignId  String
  sessionId   String?
  mapId       String?
  name        String
  status      String   @default("planned")
  round       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  campaign Campaign         @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  session  CampaignSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  map      Map?             @relation(fields: [mapId], references: [id], onDelete: SetNull)
  initiative InitiativeEntry[]
}

model InitiativeEntry {
  id          String  @id @default(cuid())
  encounterId String
  characterId String?
  tokenId     String?
  name        String
  initiative  Int
  order       Int
  active      Boolean @default(false)
  metadata    Json    @default("{}")

  encounter CombatEncounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)
  character Character?      @relation(fields: [characterId], references: [id], onDelete: SetNull)
  token     MapToken?       @relation(fields: [tokenId], references: [id], onDelete: SetNull)
}

model DiceRoll {
  id          String         @id @default(cuid())
  campaignId  String
  characterId String?
  rollerId    String
  expression  String
  label       String?
  visibility  DiceVisibility
  total       Int
  detail      Json
  revealedAt  DateTime?
  createdAt   DateTime       @default(now())

  campaign  Campaign   @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  character Character? @relation(fields: [characterId], references: [id], onDelete: SetNull)
  roller    User       @relation(fields: [rollerId], references: [id], onDelete: Cascade)
}
